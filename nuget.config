<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      Local feed pointing at the wrapper's Release output.
      Run a Release x86 build of Czf.Ant.Wrapper to update the package here.
    -->
    <add key="LocalCzfAntWrapper" value="Czf.Ant.Wrapper/bin/x86/Release" />
  </packageSources>
</configuration>
